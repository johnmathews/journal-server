# Copy to .env and fill in values.
# Only API keys are needed for ingestion. Listing, editing, and stats
# work without any API keys. The seed command also needs no keys.

# ---------------------------------------------------------------------------
# Auth secret — REQUIRED. The server refuses to start without this.
# ---------------------------------------------------------------------------
# Signs session tokens and signed URLs for the multi-user auth system.
# Generate a strong key with:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
JOURNAL_SECRET_KEY=

# Optional auth knobs (defaults shown; see src/journal/config.py):
# REGISTRATION_ENABLED=false
# SESSION_EXPIRY_DAYS=7
# Base URL used in verification / password-reset email links.
# Dev: http://localhost:5173 — Prod: https://journal.itsa-pizza.com
# APP_BASE_URL=http://localhost:5173
# Per-IP rate limiting on the anonymous auth endpoints (login, register,
# forgot-password, reset-password). On by default; 10 POSTs per 5
# minutes per IP per path.
# AUTH_RATE_LIMIT_ENABLED=true
# AUTH_RATE_LIMIT_MAX_REQUESTS=10
# AUTH_RATE_LIMIT_WINDOW_SECONDS=300
# SMTP for verification / password-reset emails (unset → emails are not
# sent; in dev, verify users directly in SQLite instead).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Anthropic API (for OCR via Claude) — required for image ingestion
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for Whisper transcription and embeddings) — required for
# voice ingestion and semantic search
OPENAI_API_KEY=sk-...

# Optional — for ingesting files shared via Slack URLs
# SLACK_BOT_TOKEN=xoxb-...

# Optional — context priming for OCR + voice transcription. Point at a
# directory of markdown files (one per category: people.md, places.md,
# topics.md, ...) to inject known proper nouns into BOTH the OCR system
# prompt AND the OpenAI Whisper `prompt` parameter so handwritten and
# spoken names get correct spellings. See journal-server/context/README.md
# and docs/context-files.md.
# OCR_CONTEXT_DIR=./context

# Anthropic prompt cache TTL for the OCR system block. "5m" or "1h".
# 1h is cheaper amortized across an ingestion session (>5 OCR calls/hr).
# OCR_CONTEXT_CACHE_TTL=1h

# Voice transcription — pass the OCR_CONTEXT_DIR markdown to Whisper as
# its `prompt` parameter (truncated to ~200 tokens). Default is on; set
# to false if you want OCR priming but no Whisper prompt.
# TRANSCRIPTION_CONTEXT_ENABLED=true

# Date-heading detection — when on, ingestion lifts a leading date in
# voice transcripts and OCR text into a markdown heading on final_text.
# raw_text is preserved verbatim. Default on. Uses Anthropic Haiku.
# DATE_HEADING_DETECTION=true
# DATE_HEADING_MODEL=claude-haiku-4-5

# Database path (default: journal.db in current directory)
# DB_PATH=/data/journal.db

# ChromaDB connection. Server defaults are localhost:8000; the dev
# compose (docker-compose.dev.yml) publishes Chroma on host port 8401,
# so for local dev set:
CHROMADB_HOST=localhost
CHROMADB_PORT=8401

# MCP server (endpoint will be at http://<host>:<port>/mcp)
# In docker-compose the in-container bind stays on 0.0.0.0 but the
# host-side port is bound to 127.0.0.1 only — see docker-compose.yml.
MCP_HOST=0.0.0.0
MCP_PORT=8400

# MCP DNS rebinding protection: hostnames the server will accept as Host
# header values. Defaults to loopback only. Add any externally-facing
# hostname here if you front the service with a reverse proxy.
# Prod also includes: journal.itsa-pizza.com
MCP_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS origins for REST API (comma-separated)
# For local dev with the journal-webapp on Vite:
# Prod: https://journal.itsa-pizza.com
API_CORS_ORIGINS=http://localhost:5173

# Timezone
# TZ=Europe/Amsterdam

# Log level (default: INFO)
# LOG_LEVEL=INFO

# Entity extraction — name the extractor uses for the journal author
# JOURNAL_AUTHOR_NAME=John
# Cosine similarity threshold above which two entity candidates are
# considered potentially the same entity (0.0-1.0)
# ENTITY_DEDUP_SIMILARITY_THRESHOLD=0.88

# ---------------------------------------------------------------------------
# Fitness pipeline (optional). See docs/fitness-tier-plan.md §1 for the
# step-by-step credential acquisition. None of these are needed unless
# you intend to ingest fitness data.
# ---------------------------------------------------------------------------
# Strava is mothballed (roadmap D8 — Strava paywalled API access on 2026-06-30):
# default false makes Strava unreachable (routes 404, Garmin-only scheduler/CLI).
STRAVA_ENABLED=false
# Strava OAuth — register an app at https://www.strava.com/settings/api
# and paste the issued client_id + client_secret here.
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# Override only if running re-auth from a non-default port.
# Prod (webapp SPA OAuth return): https://journal.itsa-pizza.com/strava/callback
# — must match the Strava app's Authorization Callback Domain (journal.itsa-pizza.com).
# STRAVA_REDIRECT_URI=http://localhost:8400/strava/callback

# Garmin Connect credentials are per-user (connect via the webapp
# Settings panel or `journal fitness-reauth-garmin`), not env vars.

# Pushover fires after this many consecutive transient sync failures
# (D5 alerting taxonomy — fire-after-N rather than per-failure).
# FITNESS_TRANSIENT_FAILURE_THRESHOLD=3

# Backfill window. Defaults to 2026-01-01 (the start of journal data,
# the only window where mood-vs-fitness correlation is meaningful).
# FITNESS_BACKFILL_START=2026-01-01
