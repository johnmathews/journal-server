# Anthropic API (for OCR)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for Whisper transcription and embeddings)
OPENAI_API_KEY=sk-...

# Database path (default: journal.db in current directory)
# DB_PATH=/data/journal.db

# ChromaDB connection (default: localhost:8000)
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8000

# MCP server (default: 0.0.0.0:8000)
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# Log level (default: INFO)
# LOG_LEVEL=INFO
